direction: right

vars: {
  사람색: "#F6E7C1"
  화면색: "#F3C24D"
  계층색: "#4E73B8"
  서비스색: "#6B8ED6"
  핵심색: "#4567B2"
  확장색: "#F2C14E"
  저장색: "#7C67C2"
  데이터색: "#4CAF60"
  흐름색: "#8A6D1A"
  글자색: "#FFFFFF"
  안내색: "#F3F4F7"
}

title: "쉽게 보는 AI 상담 구조"

왼쪽영역: {
  direction: down
}

오른쪽영역: {
  direction: down
}

사용자: "사용자" {
  shape: person
  style.fill: ${사람색}
}

왼쪽영역.화면영역: "상단 영역" {
  style.fill: ${계층색}
  style.font-color: ${글자색}

  사용자화면: "사용자 화면" {
    style.fill: ${화면색}
  }

  요청처리: "요청 처리 영역" {
    style.fill: ${서비스색}
    style.font-color: ${글자색}
  }
}

왼쪽영역.서비스영역: "서비스 영역" {
  style.fill: ${계층색}
  style.font-color: ${글자색}
  direction: right

  대화서비스: "대화 처리 서비스" {
    style.fill: ${서비스색}
    style.font-color: ${글자색}
  }

  음성서비스: "음성·이미지 서비스" {
    style.fill: ${서비스색}
    style.font-color: ${글자색}
  }

  추천서비스: "추천 질문 서비스" {
    style.fill: ${서비스색}
    style.font-color: ${글자색}
  }

  지식서비스: "지식 관리 서비스" {
    style.fill: ${서비스색}
    style.font-color: ${글자색}
  }
}

왼쪽영역.핵심영역: "중앙 핵심" {
  style.fill: ${계층색}
  style.font-color: ${글자색}
  direction: right

  외부연결: "OpenAI·Gemini 연결" {
    style.fill: ${확장색}
  }

  검색기능: "웹 검색·FAISS" {
    style.fill: ${확장색}
  }

  AI핵심엔진: "AI 핵심 엔진\n질문 이해 · 답변 생성" {
    style.fill: ${핵심색}
    style.font-color: ${글자색}
  }

  응답가공: "응답 가공 기능" {
    style.fill: ${확장색}
  }
}

왼쪽영역.저장영역: "하단 영역" {
  style.fill: ${계층색}
  style.font-color: ${글자색}
  direction: right

  지식저장소: "파일 지식 저장소" {
    shape: cylinder
    style.fill: ${데이터색}
    style.font-color: ${글자색}
  }

  상태저장소: "메모리 상태 저장" {
    style.fill: ${저장색}
    style.font-color: ${글자색}
  }

  데이터저장소: "PostgreSQL" {
    shape: cylinder
    style.fill: ${데이터색}
    style.font-color: ${글자색}
  }
}

오른쪽영역.이벤트영역: "오른쪽 흐름" {
  style.stroke-dash: 6
  style.fill: ${안내색}
  direction: down

  요청이벤트: "요청" {
    style.fill: ${서비스색}
    style.font-color: ${글자색}
  }

  처리이벤트: "처리" {
    style.fill: ${흐름색}
    style.font-color: ${글자색}
  }

  결과이벤트: "결과" {
    style.fill: ${데이터색}
    style.font-color: ${글자색}
  }
}

사용자 -> 왼쪽영역.화면영역.사용자화면: 요청 흐름
왼쪽영역.화면영역.사용자화면 -> 왼쪽영역.화면영역.요청처리: 요청 흐름

왼쪽영역.화면영역.요청처리 -> 왼쪽영역.서비스영역.대화서비스: 요청 흐름
왼쪽영역.화면영역.요청처리 -> 왼쪽영역.서비스영역.음성서비스: 요청 흐름
왼쪽영역.화면영역.요청처리 -> 왼쪽영역.서비스영역.추천서비스: 요청 흐름
왼쪽영역.화면영역.요청처리 -> 왼쪽영역.서비스영역.지식서비스: 요청 흐름

왼쪽영역.서비스영역.대화서비스 -> 왼쪽영역.핵심영역.AI핵심엔진: 처리 흐름
왼쪽영역.서비스영역.음성서비스 -> 왼쪽영역.핵심영역.AI핵심엔진: 처리 흐름
왼쪽영역.서비스영역.추천서비스 -> 왼쪽영역.핵심영역.AI핵심엔진: 처리 흐름
왼쪽영역.서비스영역.지식서비스 -> 왼쪽영역.핵심영역.AI핵심엔진: 처리 흐름

왼쪽영역.핵심영역.외부연결 -> 왼쪽영역.핵심영역.AI핵심엔진: 처리 흐름
왼쪽영역.핵심영역.검색기능 -> 왼쪽영역.핵심영역.AI핵심엔진: 처리 흐름
왼쪽영역.핵심영역.AI핵심엔진 -> 왼쪽영역.핵심영역.응답가공: 처리 흐름

왼쪽영역.저장영역.지식저장소 -> 왼쪽영역.서비스영역.지식서비스: 데이터 흐름
왼쪽영역.저장영역.상태저장소 -> 왼쪽영역.서비스영역.대화서비스: 데이터 흐름
왼쪽영역.저장영역.데이터저장소 -> 왼쪽영역.화면영역.요청처리: 데이터 흐름

왼쪽영역.화면영역.요청처리 -> 오른쪽영역.이벤트영역.요청이벤트: 처리 흐름
오른쪽영역.이벤트영역.요청이벤트 -> 오른쪽영역.이벤트영역.처리이벤트: 처리 흐름
오른쪽영역.이벤트영역.처리이벤트 -> 오른쪽영역.이벤트영역.결과이벤트: 처리 흐름

style: {
  font: "Pretendard"
  text-transform: none
}
